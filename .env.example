# Datenbank
DATABASE_URL=postgresql+psycopg://preisopt:preisopt@localhost:5432/preisopt

# Session-Cookie (siehe ADR 0003). In Produktion unbedingt durch zufälligen Wert ersetzen.
SESSION_SECRET=change-me

# App-Umgebung: development | production
APP_ENV=development

# LLM-Provider (Gemini, siehe ADR 0002)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Pfad zum Frontend-Verzeichnis (wird von FastAPI StaticFiles ausgeliefert)
FRONTEND_DIR=../frontend

# TTL für Preisvorschläge (Human-in-the-Loop, UC-03)
SUGGESTION_TTL_MINUTES=15
